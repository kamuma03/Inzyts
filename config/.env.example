# ═══════════════════════════════════════════════════════════════════
# Inzyts Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env in the project root and fill in your values.
#
#   cp config/.env.example .env
#
# Variables prefixed with INZYTS__ map to nested config via Pydantic.
# Delimiter: INZYTS__<section>__<key>  (double underscore)
#
# REQUIRED variables (docker-compose will refuse to start without them):
#   POSTGRES_PASSWORD, INZYTS_API_TOKEN, JWT_SECRET_KEY, ADMIN_PASSWORD
#   + at least one LLM API key matching INZYTS__LLM__DEFAULT_PROVIDER
# ═══════════════════════════════════════════════════════════════════


# ── LLM Provider ─────────────────────────────────────────────────
# Which provider to use by default: anthropic | openai | ollama | gemini
INZYTS__LLM__DEFAULT_PROVIDER=anthropic

# Global LLM defaults
# INZYTS__LLM__TEMPERATURE=0.1
# INZYTS__LLM__MAX_TOKENS=8192

# ── Anthropic ──
INZYTS__LLM__ANTHROPIC_MODEL=claude-sonnet-4-6
INZYTS__LLM__ANTHROPIC_API_KEY=sk-ant-xxx   # REQUIRED if DEFAULT_PROVIDER=anthropic

# ── OpenAI ──
# INZYTS__LLM__OPENAI_MODEL=gpt-4o
# OPENAI_API_KEY=sk-xxx

# ── Google Gemini ──
# INZYTS__LLM__GEMINI_MODEL=gemini-3-pro-preview
# GOOGLE_API_KEY=AIza-xxx

# ── Ollama (local) ──
# INZYTS__LLM__OLLAMA_BASE_URL=http://localhost:11434
# INZYTS__LLM__OLLAMA_MODEL=qwen2.5:32b


# ── Database (PostgreSQL) ────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me   # REQUIRED — no default in docker-compose
POSTGRES_DB=inzyts
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# DB_MAX_RETRIES=15
# DB_RETRY_INTERVAL=2


# ── Redis (Celery broker + WebSocket pub/sub) ────────────────────
REDIS_URL=redis://localhost:6379/0


# ── Security ─────────────────────────────────────────────────────
# API bearer token for worker/server-to-server calls.
# Generate with: openssl rand -hex 32
# REQUIRED — must be set before starting the server.
INZYTS_API_TOKEN=change_me   # REQUIRED

# JWT signing secret for user authentication.
# Generate with: openssl rand -hex 32
# REQUIRED — docker-compose will fail if unset.
JWT_SECRET_KEY=change_me   # REQUIRED

# Default admin credentials — used only on first boot when no users exist.
# Change ADMIN_PASSWORD before deploying to production.
# REQUIRED — docker-compose will fail if ADMIN_PASSWORD is unset.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me   # REQUIRED

# NOTE: Do NOT add VITE_API_TOKEN here or in docker-compose.yml.
# Vite bakes VITE_* vars into the compiled JS bundle (visible in static assets).
# The JWT is obtained at runtime via the login form and stored in sessionStorage only.


# ── Sandbox network isolation (DEFAULT ON) ───────────────────────
# The worker container's entrypoint installs an iptables OUTPUT allowlist
# at boot, dropping egress to anything except: loopback, DNS, db/redis on
# the docker network, and the LLM provider hostnames below. Closes the
# raw-socket exfiltration risk from kernel-sandboxed user code. The
# NET_ADMIN cap is granted in docker-compose.yml so this works out of
# the box.
#
# Opt out (returns to proxy-blackhole-only mode — still defends against
# casual urllib/requests egress, but raw sockets via ctypes are reachable):
# INZYTS_NETWORK_ISOLATION=off

# Override the default LLM-provider allowlist. Space-separated hostnames.
# Resolved at container startup; restart the worker if their IPs rotate.
# INZYTS_EGRESS_ALLOWLIST="api.anthropic.com api.openai.com generativelanguage.googleapis.com"

# Allow Ollama running on the host (host.docker.internal). Auto-enabled
# when INZYTS__LLM__DEFAULT_PROVIDER=ollama; set this to force-allow
# regardless of provider.
# INZYTS_ALLOW_HOST_DOCKER_INTERNAL=1

# Additional internal docker-network hostnames to allowlist (rare).
# INZYTS_INTERNAL_HOSTS="custom-service"


# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated or JSON array of allowed origins.
# PRODUCTION: Change these to your actual domain(s) only!
# e.g. ALLOWED_ORIGINS=["https://myapp.example.com"]
ALLOWED_ORIGINS=["http://localhost:5173", "http://localhost:8000", "http://127.0.0.1:5173"]


# ── File Paths ───────────────────────────────────────────────────
# Host directory for datasets (mounted into Docker container)
# DATASETS_DIR=/path/to/your/datasets

# Output directory for generated notebooks
# INZYTS__OUTPUT_DIR=output

# Upload directory for user-uploaded CSV files
# UPLOAD_DIR=data/uploads

# Log directory
# LOG_DIR=logs

# Log level: DEBUG | INFO | WARNING | ERROR
# INZYTS__LOG_LEVEL=INFO


# ── SQL Agent Limits ─────────────────────────────────────────────
# Maximum rows returned by the autonomous SQL agent query.
# Increase if you need larger extracts; lower to reduce memory use.
# SQL_MAX_ROWS=200000

# Maximum columns returned by the autonomous SQL agent query.
# Guards against OOM from wide SELECT * results.
# SQL_MAX_COLS=500


# ── Python Cache ─────────────────────────────────────────────────
# Consolidate all __pycache__ directories under .cache/pycache/
PYTHONPYCACHEPREFIX=.cache/pycache
